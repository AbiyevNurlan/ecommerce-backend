# ═══════════════════════════════════════════════════════════════
# ITBrains E-Commerce — Environment Variables
# ═══════════════════════════════════════════════════════════════
# Bu faylı .env olaraq kopyalayın və dəyərləri öz mühitinizə uyğun dəyişin:
#   cp .env.example .env
#
# ⚠️  .env faylı .gitignore-dadır — GitHub-a PUSH ETMƏYİN!
# ═══════════════════════════════════════════════════════════════

# ── PostgreSQL ────────────────────────────────────────────────
# Verilənlər bazasının adı
DB_NAME=ecommerce_db

# DB istifadəçi adı
DB_USERNAME=postgres

# DB şifrəsi — mütləq dəyişin!
DB_PASSWORD=your_password_here

# DB host — Docker Compose istifadə edəndə "db" saxlayın
DB_HOST=db

# DB port — standart PostgreSQL portu
DB_PORT=5432

# ── Spring Boot ───────────────────────────────────────────────
# Aktiv profil: dev (lokal), prod (Docker/production)
SPRING_PROFILES_ACTIVE=prod

# ── Upload ────────────────────────────────────────────────────
# Məhsul şəkillərinin saxlanılacağı qovluq (konteyner daxili)
UPLOAD_DIR=/app/uploads
